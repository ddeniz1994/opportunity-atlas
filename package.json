{
  "name": "opportunity-atlas-backend",
  "version": "0.2.0",
  "description": "AI-powered news aggregator for growth teams",
  "type": "module",
  "main": "opportunity-atlas-backend.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node opportunity-atlas-backend.js",
    "dev": "NODE_ENV=development nodemon opportunity-atlas-backend.js",
    "test:api": "curl http://localhost:3001/api/opportunities",
    "test:stats": "curl http://localhost:3001/api/stats",
    "test:fetch": "curl -X POST http://localhost:3001/api/fetch"
  },
  "keywords": [
    "growth",
    "news",
    "aggregation",
    "ai",
    "atlas",
    "saas"
  ],
  "author": "Deno",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.2",
    "node-fetch": "^3.3.0",
    "pg": "^8.11.3",
    "rss-parser": "^3.13.0",
    "sqlite": "^5.0.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
