# Opportunity Atlas - Environment Variables Template
# Copy this to .env and fill in your values

# Claude API (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Node environment
NODE_ENV=development

# Database (leave blank for SQLite in dev, use PostgreSQL URL in production)
# Example PostgreSQL: postgresql://user:password@host:5432/dbname
# Leave blank for in-memory SQLite
DATABASE_URL=

# Server port (optional, defaults to 3001)
PORT=3001

# Optional: CORS allowed origins (for production)
# CORS_ORIGIN=https://yourdomain.com
